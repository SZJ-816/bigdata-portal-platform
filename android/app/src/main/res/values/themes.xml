<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZhixunPortal" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/navy_900</item>
        <item name="colorPrimaryDark">@color/navy_800</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/navy_900</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.ZhixunPortal.Splash" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.ZhixunPortal</item>
    </style>

    <style name="Theme.ZhixunPortal.Settings" parent="Theme.ZhixunPortal">
        <item name="android:statusBarColor">@color/navy_900</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.ZhixunPortal.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/navy_900</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.ZhixunPortal.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/navy_900</item>
        <item name="android:textColor">@color/navy_900</item>
    </style>

    <!-- TextInput styles -->
    <style name="Widget.ZhixunPortal.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/navy_900</item>
        <item name="hintTextColor">@color/navy_900</item>
    </style>
</resources>
