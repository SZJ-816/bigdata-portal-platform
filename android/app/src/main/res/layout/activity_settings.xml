<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/navy_900"
        android:padding="24dp"
        android:fitsSystemWindows="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="配置服务器连接地址"
            android:textColor="#AAFFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- First launch welcome card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFirstLaunch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardBackgroundColor="#E8F0FE"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👋 欢迎使用智讯"
                        android:textColor="@color/navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="请输入服务器地址以连接到后端服务。如果前端和后端部署在同一地址，只需填一个即可。"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Main server URL (single field - used for both frontend and API) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器地址"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.ZhixunPortal.TextInputLayout"
                app:startIconDrawable="@drawable/ic_link"
                app:helperText="前端页面和后端 API 的部署地址"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:textSize="15sp"
                    android:hint="https://xxx.cpolar.cn" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Advanced toggle -->
            <TextView
                android:id="@+id/tvAdvancedToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="▸ 高级设置（分开配置前后端地址）"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:padding="4dp" />

            <!-- Advanced section - hidden by default -->
            <LinearLayout
                android:id="@+id/layoutAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="前端地址（WebView 加载）"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.ZhixunPortal.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFrontendUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="后端 API 地址（注入 localStorage）"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.ZhixunPortal.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etApiUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Debug mode -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDebugMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="启用调试模式 (WebView DevTools)"
                    android:checked="false"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestConnection"
                    style="@style/Widget.ZhixunPortal.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/settings_test_connection"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.ZhixunPortal.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/settings_save"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Version -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
